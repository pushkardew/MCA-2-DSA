   "source": [
    " #Program to Search an Element in a List\n",
    "# Search element in a list\n",
    "lst = [5, 15, 25, 35, 45]\n",
    "print(\"List:\", lst)\n",
    "key = int(input(\"Enter element to search: \"))\n",
    "if key in lst:\n",
    " print(\"Element found at index:\", lst.index(key))\n",
    "else:\n",
    " print(\"Element not found\")"
   ]
  }
